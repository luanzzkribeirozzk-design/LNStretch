<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07070E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="40dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LN STRETCH"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#FF4500"
                android:letterSpacing="0.14" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esticador de tela para Free Fire"
                android:textSize="12sp"
                android:textColor="#555577"
                android:layout_marginTop="5dp" />

            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:background="#FF4500"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- SHIZUKU STATUS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#0F0F1C"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHIZUKU"
                        android:textSize="10sp"
                        android:textColor="#FF4500"
                        android:letterSpacing="0.2"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvShizukuStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verificando..."
                        android:textSize="13sp"
                        android:textColor="#BBBBDD"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnShizuku"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="AUTORIZAR"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:backgroundTint="#FF4500" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- STATUS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0F0F1C"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textSize="10sp"
                    android:textColor="#7C00FF"
                    android:letterSpacing="0.2"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textSize="13sp"
                    android:textColor="#AAAACC"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- SLIDER LARGURA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#0F0F1C"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LARGURA DO STRETCH"
                        android:textSize="11sp"
                        android:textColor="#FF4500"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10% -- 40%"
                        android:textSize="11sp"
                        android:textColor="#444466" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvSliderLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+15%"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="10%"
                        android:textSize="10sp"
                        android:textColor="#444466"
                        android:gravity="start" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="25%"
                        android:textSize="10sp"
                        android:textColor="#444466"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="40%"
                        android:textSize="10sp"
                        android:textColor="#444466"
                        android:gravity="end" />

                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbarStretch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:progressTint="#FF4500"
                    android:thumbTint="#FF6B00" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recomendado: 15-25%. Acima de 30% pode distorcer."
                    android:textSize="11sp"
                    android:textColor="#444466"
                    android:layout_marginTop="10dp"
                    android:gravity="center" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BOTOES STRETCH / RESTAURAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnStretch"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="ESTICAR"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4500" />

            <Button
                android:id="@+id/btnUnstretch"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="RESTAURAR"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#AAAACC"
                android:backgroundTint="#1A1A2E" />

        </LinearLayout>

        <!-- DIVISOR -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- OTIMIZAR -->
        <Button
            android:id="@+id/btnOptimize"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginBottom="10dp"
            android:text="OTIMIZAR FREE FIRE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C00FF" />

        <!-- ABRIR FF -->
        <Button
            android:id="@+id/btnOpenFF"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:text="ABRIR FREE FIRE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF6B00" />

        <!-- INSTRUCAO SHIZUKU -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#0A0A16"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMO USAR O SHIZUKU"
                    android:textSize="11sp"
                    android:textColor="#FF4500"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Instale o app Shizuku na Play Store\n2. Abra o Shizuku e ative via Wi-Fi\n3. Volte aqui e clique AUTORIZAR\n4. Pronto - funciona em qualquer celular!"
                    android:textSize="12sp"
                    android:textColor="#8888AA"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Play Store: pesquise por Shizuku"
                    android:textSize="11sp"
                    android:textColor="#FF4500"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
